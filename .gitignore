# EDMD — .gitignore

# ── User config ───────────────────────────────────────────────────────────────
# Personal config is never committed — only the example template is tracked.
# Your config.toml contains webhook URLs, user IDs, and personal paths.
config.toml

# ── Auth & key material ───────────────────────────────────────────────────────
# These files contain sensitive cryptographic material — never commit them.
*.key
*.pub
allowlist.ksw
ksw_client.py

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ── Build / distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg

# ── PyInstaller (if ever bundled) ─────────────────────────────────────────────
*.spec
*.exe

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Custom themes ─────────────────────────────────────────────────────────────
# Track the directory itself but ignore any CSS files placed inside it.
# Put your personal themes in themes/custom/ and they will never be committed.
themes/custom/*.css

# ── Logs and local data ───────────────────────────────────────────────────────
*.log
